---
import MelonSodaAnimation from "./MelonSodaAnimation.svelte";
import { cn } from "../lib/utils";
---

<div
  class={cn([
    "relative",
    "w-full",
    "h-screen",
    "flex",
    "flex-col",
    "justify-center",
    "items-center",
  ])}
>
  <MelonSodaAnimation client:only="svelte" />

  <nav
    class={cn([
      "nav-links",
      "h-28",
      "z-100",
      "m-2",
      "bg-opacity-20",
      "bg-gray-300/60",
      "rounded-full",
      "flex",
      "flex-col",
      "justify-center",
      "items-center",
      "fixed",
      "bottom-0",
      "left-1/2",
      "transform",
      "-translate-x-1/2",
      "p-4",
      "w-auto",
    ])}
  >
    <div class={cn(["mx-16", "gap-8", "md:inline-flex"])}>
      <a
        href="/about/"
        data-astro-reload
        class={cn([
          "text-white",
          "text-xl",
          "italic",
          "px-5",
          "py-1.5",
          "rounded-full",
          "transition-colors",
          "text-center",
        ])}
      >
        about me
      </a>
      <a
        href="/work/"
        data-astro-reload
        class={cn([
          "text-white",
          "text-xl",
          "italic",
          "px-5",
          "py-1.5",
          "rounded-full",
          "transition-colors",
          "text-center",
        ])}
      >
        work
      </a>
    </div>
  </nav>
</div>
